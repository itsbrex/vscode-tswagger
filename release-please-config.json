{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "always-update": true,
  "group-pull-request-title-pattern": "chore: release extension ${version}",
  "pull-request-title-pattern": "chore: release extension ${version}",
  "release-type": "node",
  "tag-separator": "-",
  "packages": {
    ".": {
      "component": "extension",
      "include-component-in-tag": true,
      "include-v-in-tag": true,
      "exclude-paths": [
        ".changeset",
        "packages",
        "pnpm-lock.yaml"
      ],
      "changelog-path": "CHANGELOG.md",
      "changelog-sections": [
        {
          "type": "feat",
          "section": "Added"
        },
        {
          "type": "fix",
          "section": "Fixed"
        },
        {
          "type": "perf",
          "section": "Changed"
        },
        {
          "type": "refactor",
          "section": "Changed"
        },
        {
          "type": "style",
          "section": "Changed"
        },
        {
          "type": "docs",
          "section": "Changed"
        },
        {
          "type": "build",
          "section": "Changed"
        },
        {
          "type": "deps",
          "section": "Changed"
        },
        {
          "type": "security",
          "section": "Security"
        },
        {
          "type": "deprecate",
          "section": "Deprecated"
        },
        {
          "type": "remove",
          "section": "Removed"
        }
      ]
    }
  }
}
